<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootContainer" spacing="20" styleClass="main-container, light-theme" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.solofinassas.controller.DashboardController">

    <VBox alignment="CENTER" styleClass="banner-container" maxWidth="Infinity">
        <ImageView fx:id="imgBanner" fitHeight="180" fitWidth="900" preserveRatio="false">
            <image>
                <Image url="@imagem/Copilot_20260525_100003.png" />
            </image>
        </ImageView>
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header-box" maxWidth="Infinity">
        <ImageView fitHeight="35" fitWidth="35" preserveRatio="true">
            <image>
                <Image url="@imagem/Copilot_20260525_095748.png" />
            </image>
        </ImageView>

        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="header-title" text="Orçamento Mensal" />
            <Label styleClass="header-subtitle" text="Painel de Controle Financeiro Pessoal" />
        </VBox>

        <Button fx:id="btnTema" onAction="#handleAlternarTema" styleClass="theme-toggle-btn" text="🌓 Alternar Tema" />
    </HBox>

    <HBox spacing="15" styleClass="cards-container" maxWidth="Infinity">
        <VBox styleClass="summary-card, card-receita" HBox.hgrow="ALWAYS">
            <Label styleClass="card-title" text="Receita Total" />
            <Label fx:id="lblTotalReceita" styleClass="card-value" text="R$ 0,00" />
        </VBox>
        <VBox styleClass="summary-card, card-despesa" HBox.hgrow="ALWAYS">
            <Label styleClass="card-title" text="Despesa Total" />
            <Label fx:id="lblTotalDespesa" styleClass="card-value" text="R$ 0,00" />
        </VBox>
        <VBox styleClass="summary-card, card-poupanca" HBox.hgrow="ALWAYS">
            <Label styleClass="card-title" text="Poupança / Saldo" />
            <Label fx:id="lblTotalPoupanca" styleClass="card-value" text="R$ 0,00" />
        </VBox>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS" maxWidth="Infinity">

        <VBox spacing="12" styleClass="form-container" HBox.hgrow="NEVER" prefWidth="280" minWidth="280">
            <Label styleClass="section-title" text="➕ Nova Movimentação" />

            <VBox spacing="4">
                <Label styleClass="field-label" text="Descrição" />
                <TextField fx:id="txtDescription" promptText="Ex: Salário Estágio" styleClass="notion-input" />
            </VBox>

            <VBox spacing="4">
                <Label styleClass="field-label" text="Valor (R$)" />
                <TextField fx:id="txtAmount" promptText="0.00" styleClass="notion-input" />
            </VBox>

            <VBox spacing="4">
                <Label styleClass="field-label" text="Tipo" />
                <ComboBox fx:id="cbType" promptText="Selecione..." styleClass="notion-combo" maxWidth="Infinity" />
            </VBox>

            <VBox spacing="4">
                <Label styleClass="field-label" text="Tag / Categoria" />
                <TextField fx:id="txtTag" promptText="Ex: Trabalho, Alimentação" styleClass="notion-input" />
            </VBox>

            <Button onAction="#handleAdicionarMovimentacao" maxWidth="Infinity" styleClass="notion-button" text="Adicionar ao Registro" />
        </VBox>

        <VBox spacing="15" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <HBox spacing="15" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">

                <VBox spacing="8" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <Label styleClass="table-section-title, title-green" text="Receitas" />
                    <TableView fx:id="tabelaReceitas" styleClass="notion-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colRecDesc" text="Fonte / Item" prefWidth="150" />
                            <TableColumn fx:id="colRecValor" text="Valor" prefWidth="100" />
                            <TableColumn fx:id="colRecTag" text="Tag" prefWidth="100" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <Label styleClass="table-section-title, title-red" text="Despesas" />
                    <TableView fx:id="tabelaDespesas" styleClass="notion-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDesDesc" text="Item / Serviço" prefWidth="150" />
                            <TableColumn fx:id="colDesValor" text="Valor" prefWidth="100" />
                            <TableColumn fx:id="colDesTag" text="Tag" prefWidth="100" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

            </HBox>

            <VBox alignment="CENTER" styleClass="chart-container" prefHeight="180" minHeight="150" HBox.hgrow="ALWAYS">
                <PieChart fx:id="financeChart" labelsVisible="true" maxWidth="Infinity" maxHeight="Infinity" />
            </VBox>
        </VBox>
    </HBox>
</VBox>